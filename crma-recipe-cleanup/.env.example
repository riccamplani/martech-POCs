# ---- Salesforce auth ----
# Choose ONE auth mode: "cli" (dev) or "jwt" (headless/CI)
SF_AUTH_MODE=cli

# CLI mode: the alias you used with `sf org login web --alias prod`
SF_CLI_ALIAS=prod

# JWT mode (server-to-server, no password). Create a Connected App with a cert.
SF_LOGIN_URL=https://login.salesforce.com        # use https://test.salesforce.com for sandboxes
SF_CLIENT_ID=                                     # Connected App consumer key
SF_USERNAME=                                      # integration user username
SF_JWT_KEY_PATH=./secrets/server.key              # private key matching the uploaded cert

# Salesforce API version (bump as needed)
SF_API_VERSION=62.0

# ---- Claude API (for field classification) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Analysis tuning ----
# Fields below this population % AND with zero dependencies are candidates to deprecate.
POPULATION_THRESHOLD=0.02
