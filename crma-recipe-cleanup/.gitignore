# secrets & env
.env
secrets/
*.key
*.pem

# python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# generated output (keep the dir, ignore contents)
output/*
!output/.gitkeep

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# OS / editor
.DS_Store
.vscode/settings.json

# extracted + generated recipe artifacts (keep scope.txt + objects.yaml)
recipes/input/*.json
recipes/output/*
!recipes/input/.gitkeep
!recipes/output/.gitkeep

# verify snapshots contain production dataset row counts — keep local
recipes/verify/
