    "FORMULA0": {
      "action": "formula",
      "parameters": {
        "expressionType": "SQL",
        "fields": [
          {
            "defaultValue": "",
            "formulaExpression": "case when\r\n(NumberOfEmployees >=20 and NumberOfEmployees <35)\r\nthen '20-34'\r\nwhen (NumberOfEmployees >=35 and NumberOfEmployees <=50)\r\nthen '35-50'\r\nelse 'ikke gruppert'\r\nend\r\n",
