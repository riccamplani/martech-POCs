    "FORMULA1": {
      "action": "formula",
      "parameters": {
        "expressionType": "SQL",
        "fields": [
          {
            "defaultValue": "",
            "formulaExpression": "Case \r\nwhen\r\n(VisitingCounty__c = 'Agder'\r\nor VisitingCounty__c = 'AGDER'\r\nor VisitingCounty__c = 'Telemark'\r\nor VisitingCounty__c = 'TELEMARK')\r\nthen 'Kristiansand'\r\nwhen\r\n(VisitingCounty__c = 'Oslo'\r\nor VisitingCounty__c = 'OSLO'\r\nor VisitingCounty__c = 'Østfold'\r\nor VisitingCounty__c = 'ØSTFOLD'\r\nor VisitingCounty__c = 'Akershus'\r\nor VisitingCounty__c = 'AKERSHUS'\r\nor VisitingCounty__c = 'Buskerud'\r\nor VisitingCounty__c = 'BUSKERUD'\r\nor VisitingCounty__c = 'Vestfold'\r\nor VisitingCounty__c = 'VESTFOLD'\r\nor VisitingCounty__c = 'Innlandet'\r\nor VisitingCounty__c = 'INNLANDET')\r\nthen 'Fornebu'\r\nwhen\r\n(VisitingCounty__c = 'Trøndelag'\r\nor VisitingCounty__c = 'TRØNDELAG'\r\nor VisitingCounty__c = 'MØRE OG ROMSDAL'\r\nor VisitingCounty__c = 'Møre og Romsdal')\r\nthen 'Trondheim'\r\nwhen\r\n(VisitingCounty__c = 'Nordland'\r\nor VisitingCounty__c = 'NORDLAND'\r\nor VisitingCounty__c = 'Troms'\r\nor VisitingCounty__c = 'TROMS'\r\nor VisitingCounty__c = 'Finnmark'\r\nor VisitingCounty__c = 'FINNMARK')\r\nthen 'Bodø'\r\nwhen\r\n(VisitingCounty__c = 'Rogaland'\r\nor VisitingCounty__c = 'ROGALAND'\r\nor VisitingCounty__c = 'Vestland'\r\nor VisitingCounty__c = 'VESTLAND')\r\nthen 'Stavanger'\r\nelse 'Ikke gruppert'\r\nend\r\n\r\n",
            "label": "Avdeling Hunter Direkte",
            "name": "Avdeling_hunter_direkte",
            "precision": 255,
            "type": "TEXT"
          }
        ]
      },
